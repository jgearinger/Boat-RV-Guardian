---
import Layout from '../layouts/Layout.astro';

const categories = [
	{
		id: 'water',
		icon: '🌊',
		color: '#38bdf8',
		glow: 'rgba(14, 165, 233, 0.12)',
		title: 'City Water Control',
		blurb: 'Meter every gallon at the hookup and slam the valve shut the instant a line lets go.',
		kit: {
			name: 'City Water Protection Kit',
			desc: 'Everything you need to monitor and control your water hookup in one bundle.',
			price: '~$135–160',
			includes: ['LinkTap G2S Smart Valve', 'Wi-Fi Gateway'],
			images: [
				{ src: '/smart_valve.png', bg: 'light' },
				{ src: '/wifi_gateway.png', bg: 'light' },
			],
			href: '#',
		},
		devices: [
			{
				name: 'LinkTap G2S Smart Valve',
				img: '/smart_valve.png',
				bg: 'light',
				tag: 'Required',
				tagType: 'req',
				price: '~$100',
				desc: 'Use the G2S (or newer G1S/G4S) — its built-in flow meter tracks exact gallons used and enables volume-based shutoffs older models can\'t do.',
				href: '#',
			},
			{
				name: 'LinkTap Gateway',
				img: '/wifi_gateway.png',
				bg: 'light',
				tag: 'Required',
				tagType: 'req',
				price: '~$60',
				desc: 'Bridges your Wi-Fi to the valve over Zigbee and exposes the Local API endpoints for instant, cloud-free control.',
				href: '#',
			},
		],
	},
	{
		id: 'flood',
		icon: '🚨',
		color: '#f87171',
		glow: 'rgba(239, 68, 68, 0.12)',
		title: 'Flood & High Water',
		blurb: 'Drop sensors in every low spot and get an alarm the second water shows up.',
		devices: [
			{
				name: 'Shelly Flood Gen4',
				img: '/shelly_flood_gen4.png',
				bg: 'light',
				tag: 'Required',
				tagType: 'req',
				price: '~$30',
				desc: 'A low-cost, battery-powered Wi-Fi sensor. Place it in bilges, sumps, or under sinks to catch leaks instantly and trigger alarms.',
				href: '#',
			},
		],
	},
	{
		id: 'battery',
		icon: '🔋',
		color: '#34d399',
		glow: 'rgba(16, 185, 129, 0.12)',
		title: 'Battery Monitoring',
		blurb: 'Watch house and starter banks so a dead battery never strands you — or your bilge pump.',
		kit: {
			name: '12V Battery Monitoring Kit',
			desc: 'The complete package to wire into your 12V system safely, with battery protection built in.',
			price: '~$45',
			includes: ['Shelly Plus Uni', 'Inline Fused Wiring Harness', 'Waterproof Junction Box'],
			images: [
				{ src: '/shelly_plus_uni.png', bg: 'light' },
				{ src: '/fused_harness.png', bg: 'light' },
				{ src: '/junction_box.png', bg: 'light' },
			],
			href: '#',
		},
		devices: [
			{
				name: 'Shelly Plus Uni',
				img: '/shelly_plus_uni.png',
				bg: 'light',
				tag: 'Required',
				tagType: 'req',
				price: '~$25',
				desc: 'Wires into your 12V house and starter systems for constant, precision voltage monitoring and status detection.',
				href: 'https://amzn.to/4oHxFP3',
			},
			{
				name: 'Inline Fused Wiring Harness',
				img: '/fused_harness.png',
				bg: 'light',
				tag: 'Recommended',
				tagType: 'rec',
				price: '~$12',
				desc: 'Fused ring-terminal leads to wire the Shelly Uni safely onto your battery terminals — the inline fuse protects the circuit.',
				href: 'https://amzn.to/4ezRPpz',
			},
			{
				name: 'Waterproof Junction Box',
				img: '/junction_box.png',
				bg: 'light',
				tag: 'Recommended',
				tagType: 'rec',
				price: '~$10',
				desc: 'An IP65-rated enclosure to mount and weatherproof the Shelly Uni and its wiring in exposed or damp 12V installs.',
				href: 'https://amzn.to/4vXFPVO',
			},
		],
	},
	{
		id: 'shore-power',
		icon: '⚡',
		color: '#fbbf24',
		glow: 'rgba(245, 158, 11, 0.12)',
		title: 'Shore Power Monitoring',
		blurb: 'Know the instant the marina or campground drops power — before your fridge does.',
		devices: [
			{
				name: 'Shelly PM Mini Gen3',
				img: '/shelly_pm_mini.png',
				bg: 'light',
				tag: 'Required',
				tagType: 'req',
				price: '~$25',
				desc: 'A compact AC power meter. Wire it to your shore power line to track voltage and consumption and get instant black-out notifications.',
				href: '#',
			},
		],
	},
	{
		id: 'environmental',
		icon: '🌡️',
		color: '#a78bfa',
		glow: 'rgba(139, 92, 246, 0.12)',
		title: 'Environmental',
		blurb: 'Temperature and humidity tracking is on the bench.',
		comingSoon: 'Supported hardware for temperature and humidity tracking is being tested and validated.',
		devices: [],
	},
];
---

<Layout title="Supported Devices | Boat & Rv Guardian">
	<section class="devices-hero">
		<div class="container">
			<span class="hero-eyebrow">Hardware</span>
			<h1>Build your protection system</h1>
			<p>Boat &amp; RV Guardian runs on affordable, off-the-shelf LinkTap and Shelly hardware. Pick a ready-made kit or add components as you grow — every part below shows an estimated price.</p>
			<span class="affiliate-note">Prices are estimates and vary by region. Buying through these affiliate links helps support the open-source project at no extra cost to you.</span>
		</div>
	</section>

	<nav class="category-nav">
		<div class="container category-nav-inner">
			{categories.map((c) => (
				<a href={`#${c.id}`} style={`--dot:${c.color}`}><span class="nav-dot"></span>{c.title}</a>
			))}
		</div>
	</nav>

	<div class="container main-content">
		{categories.map((cat) => (
			<section class="device-category" id={cat.id} style={`--cat-color:${cat.color}; --cat-glow:${cat.glow}`}>
				<header class="category-head">
					<span class="category-icon">{cat.icon}</span>
					<div>
						<h2>{cat.title}</h2>
						<p>{cat.blurb}</p>
					</div>
				</header>

				{cat.kit && (
					<div class="kit-banner glass-card">
						<div class={`kit-images bg-${cat.kit.images[0].bg}`}>
							{cat.kit.images.map((im, i) => (
								<>
									{i > 0 && <span class="kit-plus">+</span>}
									<img src={im.src} alt="" class="kit-img" />
								</>
							))}
						</div>
						<div class="kit-body">
							<div class="kit-label-row">
								<span class="kit-label">Starter Kit</span>
								<span class="kit-price">Est. {cat.kit.price}</span>
							</div>
							<h3>{cat.kit.name}</h3>
							<p>{cat.kit.desc}</p>
							<ul class="kit-includes">
								{cat.kit.includes.map((item) => <li>{item}</li>)}
							</ul>
							<a href={cat.kit.href} class="btn btn-primary kit-cta">Kit Assembly Guide</a>
						</div>
					</div>
				)}

				{cat.devices.length > 0 && (
					<div class={`components-grid ${cat.devices.length < 3 ? 'few' : ''}`}>
						{cat.devices.map((d) => (
							<article class="glass-card device-card">
								<div class={`device-image-container bg-${d.img ? d.bg : 'placeholder'}`}>
									{d.img
										? <img src={d.img} alt={d.name} class="device-image" />
										: <span class="device-image-placeholder">{d.icon}</span>}
								</div>
								<span class={`need-tag need-${d.tagType}`}>{d.tag}</span>
								<h3>{d.name}</h3>
								<p>{d.desc}</p>
								<div class="device-foot">
									<span class="device-price">{d.price}</span>
									<a href={d.href} class="buy-link">Buy on Amazon &rarr;</a>
								</div>
							</article>
						))}
					</div>
				)}

				{cat.comingSoon && (
					<div class="coming-soon">
						<span class="coming-soon-tag">Coming Soon</span>
						<p>{cat.comingSoon}</p>
					</div>
				)}
			</section>
		))}

		<section class="cost-summary">
			<div class="glass-card cost-card">
				<h2>What a full setup costs</h2>
				<p>The app is free and always will be — your only cost is hardware. Here's a typical end-to-end build. Mix and match to fit your rig; you don't need every category.</p>
				<div class="cost-table">
					<div class="cost-row header">
						<div>Item</div>
						<div>Estimated cost</div>
					</div>
					<div class="cost-row">
						<div>City Water Protection Kit</div>
						<div>~$135–160</div>
					</div>
					<div class="cost-row">
						<div>12V Battery Monitoring Kit</div>
						<div>~$45</div>
					</div>
					<div class="cost-row">
						<div>Shelly Flood Gen4 (×2)</div>
						<div>~$60</div>
					</div>
					<div class="cost-row">
						<div>Shelly PM Mini Gen3</div>
						<div>~$25</div>
					</div>
					<div class="cost-row total">
						<div><strong>Typical full build</strong></div>
						<div><strong>~$265–290</strong></div>
					</div>
				</div>
				<p class="cost-note">*Estimates only — prices vary by region and retailer. The software is free and open-source under GPL-3.0.</p>
			</div>
		</section>
	</div>
</Layout>

<style>
	/* Hero */
	.devices-hero {
		text-align: center;
		padding: 4rem 0 2.5rem;
		background: radial-gradient(circle at 50% 0%, rgba(14, 165, 233, 0.08) 0%, transparent 60%);
	}

	.hero-eyebrow {
		display: inline-block;
		font-family: var(--font-heading);
		font-size: 0.8rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 2px;
		color: var(--accent-color);
		margin-bottom: 1rem;
	}

	.devices-hero h1 {
		font-size: 2.75rem;
		margin-bottom: 1rem;
	}

	.devices-hero p {
		font-size: 1.1rem;
		color: var(--text-muted);
		max-width: 620px;
		margin: 0 auto 1.5rem;
	}

	.affiliate-note {
		display: inline-block;
		font-size: 0.8rem;
		color: var(--text-muted);
		background: var(--surface-color);
		border: 1px solid var(--surface-border);
		padding: 0.4rem 1rem;
		border-radius: 20px;
	}

	/* Sticky category nav */
	.category-nav {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(11, 15, 25, 0.85);
		backdrop-filter: blur(12px);
		border-top: 1px solid var(--surface-border);
		border-bottom: 1px solid var(--surface-border);
		margin-bottom: 3.5rem;
	}

	.category-nav-inner {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		justify-content: center;
		padding-top: 0.8rem;
		padding-bottom: 0.8rem;
	}

	.category-nav a {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--text-muted);
		padding: 0.4rem 0.9rem;
		border-radius: 20px;
		border: 1px solid transparent;
		transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
	}

	.category-nav a:hover {
		color: #fff;
		background: var(--surface-color);
		border-color: var(--surface-border);
	}

	.nav-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--dot);
	}

	/* Category section */
	.device-category {
		margin-bottom: 4rem;
		scroll-margin-top: 5rem;
	}

	.category-head {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding-bottom: 1.25rem;
		margin-bottom: 1.75rem;
		border-bottom: 1px solid var(--surface-border);
		position: relative;
	}

	.category-head::after {
		content: "";
		position: absolute;
		bottom: -1px;
		left: 0;
		width: 80px;
		height: 2px;
		background: var(--cat-color);
	}

	.category-icon {
		font-size: 1.6rem;
		width: 52px;
		height: 52px;
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 14px;
		background: var(--cat-glow);
		border: 1px solid var(--cat-color);
	}

	.category-head h2 {
		font-size: 1.6rem;
		margin-bottom: 0.2rem;
	}

	.category-head p {
		color: var(--text-muted);
		font-size: 0.98rem;
		margin: 0;
	}

	/* Featured kit banner */
	.kit-banner {
		display: flex;
		gap: 2rem;
		align-items: stretch;
		padding: 1.5rem;
		margin-bottom: 1.75rem;
		background: linear-gradient(135deg, var(--cat-glow), transparent 70%);
		border-color: var(--cat-color);
	}

	.kit-banner:hover {
		transform: none;
	}

	.kit-images {
		flex: 0 0 38%;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		border-radius: 12px;
		padding: 1.25rem;
		min-height: 180px;
	}

	.kit-img {
		max-height: 100px;
		max-width: 30%;
		min-width: 0;
		object-fit: contain;
	}

	.kit-plus {
		font-size: 2rem;
		color: var(--text-muted);
		font-weight: 300;
		flex-shrink: 0;
	}

	.kit-body {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 0.5rem 0.5rem 0.5rem 0;
	}

	.kit-label-row {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.6rem;
	}

	.kit-label {
		display: inline-block;
		font-family: var(--font-heading);
		font-size: 0.72rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: var(--cat-color);
	}

	.kit-price {
		font-family: var(--font-heading);
		font-size: 0.78rem;
		font-weight: 600;
		color: var(--text-main);
		background: var(--surface-color);
		border: 1px solid var(--surface-border);
		border-radius: 20px;
		padding: 0.15rem 0.7rem;
	}

	.kit-body h3 {
		font-size: 1.5rem;
		margin-bottom: 0.6rem;
	}

	.kit-body p {
		color: var(--text-muted);
		margin: 0 0 1rem;
		line-height: 1.6;
	}

	.kit-includes {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5rem;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.kit-includes li {
		font-size: 0.82rem;
		color: var(--text-main);
		background: var(--surface-color);
		border: 1px solid var(--surface-border);
		border-radius: 8px;
		padding: 0.35rem 0.7rem;
	}

	.kit-cta {
		align-self: flex-start;
		padding: 0.6rem 1.4rem;
	}

	/* Component grid */
	.components-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1.25rem;
	}

	.components-grid.few {
		grid-template-columns: repeat(auto-fill, minmax(260px, 300px));
		justify-content: start;
	}

	.device-card {
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		border-radius: 14px;
	}

	.device-image-container {
		width: 100%;
		height: 150px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 10px;
		margin-bottom: 1.1rem;
		overflow: hidden;
		border: 1px solid var(--surface-border);
		padding: 0.75rem;
	}

	.bg-light { background: #f4f6f8; }
	.bg-dark { background: #0d111d; }
	.bg-placeholder { background: var(--surface-color); }

	.device-image-placeholder {
		font-size: 2.75rem;
		opacity: 0.5;
	}

	.device-image {
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
		transition: transform 0.3s ease;
	}

	.device-card:hover .device-image {
		transform: scale(1.05);
	}

	.need-tag {
		display: inline-block;
		align-self: flex-start;
		padding: 0.2rem 0.65rem;
		border-radius: 6px;
		font-size: 0.68rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		margin-bottom: 0.7rem;
	}

	.need-req {
		background: rgba(14, 165, 233, 0.12);
		color: var(--accent-hover);
		border: 1px solid rgba(14, 165, 233, 0.25);
	}

	.need-rec {
		background: rgba(245, 158, 11, 0.12);
		color: #fbbf24;
		border: 1px solid rgba(245, 158, 11, 0.25);
	}

	.device-card h3 {
		font-size: 1.1rem;
		margin-bottom: 0.5rem;
	}

	.device-card p {
		color: var(--text-muted);
		font-size: 0.9rem;
		line-height: 1.55;
		flex-grow: 1;
		margin: 0 0 1.1rem;
	}

	.device-foot {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.device-price {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: 1.05rem;
		color: #fff;
	}

	.buy-link {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: 0.88rem;
		color: var(--accent-color);
		white-space: nowrap;
	}

	.buy-link:hover {
		color: var(--accent-hover);
	}

	/* Coming soon */
	.coming-soon {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
		padding: 1.5rem 1.75rem;
		border: 1px dashed var(--surface-border);
		border-radius: 14px;
		background: var(--surface-color);
	}

	.coming-soon-tag {
		font-family: var(--font-heading);
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: var(--cat-color);
		border: 1px solid var(--cat-color);
		border-radius: 20px;
		padding: 0.35rem 0.9rem;
		flex-shrink: 0;
	}

	.coming-soon p {
		margin: 0;
		color: var(--text-muted);
	}

	/* Cost summary */
	.cost-summary {
		margin: 1rem 0 2rem;
	}

	.cost-card {
		padding: 2.5rem;
	}

	.cost-card > h2 {
		font-size: 1.6rem;
		margin-bottom: 0.75rem;
	}

	.cost-card > p {
		color: var(--text-muted);
		max-width: 640px;
		margin: 0 0 1.75rem;
	}

	.cost-table {
		border: 1px solid var(--surface-border);
		border-radius: 10px;
		overflow: hidden;
		max-width: 640px;
	}

	.cost-row {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.9rem 1.25rem;
		border-bottom: 1px solid var(--surface-border);
		color: var(--text-main);
	}

	.cost-row:last-child { border-bottom: none; }

	.cost-row.header {
		background: rgba(255, 255, 255, 0.05);
		font-weight: 600;
		color: #fff;
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.cost-row.total {
		background: rgba(14, 165, 233, 0.1);
		color: #fff;
	}

	.cost-note {
		margin: 1rem 0 0;
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	/* Responsive */
	@media (max-width: 768px) {
		.devices-hero h1 { font-size: 2.1rem; }
		.cost-card { padding: 1.75rem; }

		.kit-banner {
			flex-direction: column;
			gap: 1.25rem;
		}

		.kit-images {
			flex-basis: auto;
			min-height: 150px;
		}

		.category-head h2 { font-size: 1.4rem; }
	}
</style>
