{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "notification:default",
    "notification:allow-is-permission-granted",
    "oauth:allow-start",
    "oauth:allow-cancel",
    {
      "identifier": "http:default",
      "allow": [{ "url": "http://*/*" }, { "url": "https://*/*" }]
    }
  ]
}